{
  "name": "cinegen-desktop",
  "version": "2.0.3",
  "description": "CineGen desktop application",
  "main": "main.js",
  "author": "CineGen contributors",
  "license": "MIT",
  "scripts": {
    "prestart": "node scripts/copy-backend.js",
    "start": "electron .",
    "build:front": "cd ../frontweb && npm run build",
    "copy-front": "node scripts/copy-front.js",
    "clean:unpacked": "node scripts/clean-win-unpacked.js",
    "pack": "npm run prepare-backend && npm run build:front && npm run copy-front && npm run clean:unpacked && electron-builder --dir",
    "dist": "npm run prepare-backend && npm run build:front && npm run copy-front && npm run clean:unpacked && electron-builder --win",
    "icons:mac": "node scripts/build-icons-mac.js",
    "icons:win": "node scripts/build-icons-win.js",
    "prepare:ffmpeg:mac": "node scripts/prepare-ffmpeg-mac.js",
    "prepare:ffmpeg:win": "node scripts/prepare-ffmpeg-win.js",
    "version:patch": "node ../release-tools/bump-version.js patch",
    "version:minor": "node ../release-tools/bump-version.js minor",
    "dist:mac": "bash dist-mac.sh",
    "dist:win": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/dist-win.ps1",
    "postinstall": "node scripts/copy-backend.js && electron-builder install-app-deps",
    "prepare-backend": "node scripts/copy-backend.js"
  },
  "dependencies": {
    "@volcengine/openapi": "^1.36.1",
    "@volcengine/tos-sdk": "^2.9.1",
    "adm-zip": "^0.6.0",
    "better-sqlite3": "^12.11.1",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "js-yaml": "^4.1.0",
    "jsonrepair": "^3.13.3",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.0.2",
    "sharp": "^0.34.5"
  },
  "overrides": {
    "axios": "^1.18.0",
    "@volcengine/openapi": {
      "protobufjs": "^7.6.5",
      "uuid": "^11.1.1"
    }
  },
  "devDependencies": {
    "@derhuerst/ffprobe-static": "^5.3.0",
    "@electron/asar": "^3.4.1",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "ffmpeg-static": "^5.2.0",
    "png2icons": "^2.0.1"
  },
  "build": {
    "appId": "com.cinegen.platform",
    "productName": "CineGen",
    "artifactName": "CineGen-${version}.${ext}",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "preload.js",
      "package.json",
      "assets/cinegen-trayTemplate.png",
      "assets/cinegen-trayTemplate@2x.png",
      "backend-app/**/*",
      "node_modules/**/*"
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**",
      "node_modules/sharp/**"
    ],
    "extraResources": [
      {
        "from": "frontweb-dist",
        "to": "frontweb/dist",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../backend-node/tools/ffmpeg",
        "to": "ffmpeg",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": null,
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
