{
  "appId": "com.cinegen.platform",
  "productName": "CineGen",
  "directories": {
    "output": "release"
  },
  "files": [
    "main.js",
    "preload.js",
    "package.json",
    "assets/cinegen-trayTemplate.png",
    "assets/cinegen-trayTemplate@2x.png",
    "backend-app/**/*",
    "node_modules/**/*"
  ],
  "asarUnpack": [
    "node_modules/better-sqlite3/**",
    "backend-app/tools/**"
  ],
  "extraResources": [
    {
      "from": "frontweb-dist",
      "to": "frontweb/dist",
      "filter": ["**/*"]
    },
    {
      "from": "vendor/darwin-arm64",
      "to": "ffmpeg",
      "filter": ["ffmpeg", "ffprobe", "LICENSE*"]
    }
  ],
  "mac": {
    "target": [
      { "target": "dmg", "arch": ["arm64"] }
    ],
    "category": "public.app-category.entertainment",
    "icon": "assets/cinegen.icns",
    "identity": null
  },
  "dmg": {
    "title": "${productName} ${version}",
    "artifactName": "CineGen-${version}-mac-arm64.dmg"
  }
}
